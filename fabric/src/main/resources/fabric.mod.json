{
  "schemaVersion": 1,
  "id": "jcraftpolished",
  "version": "${version}",
  "name": "JCraft: Polished",
  "description": "This simple mod adds slab, stair, wall and pressure plate variants to JCraft: Eyes Of Ender's Polished Meteorite Block",
  "authors": [
    "Arsik"
  ],
  "contact": {
    "homepage": "https://discordapp.com/channels/801259645566058528/1506544689762009168",
    "sources": "https://github.com/ArsikBarsik13/JCraft-Polished-Addon"
  },
  "license": "MIT",
  "icon": "assets/jcraftpolished/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.arsik.jcraftpolished.fabric.JCraftPolishedFabric"
    ],
    "client": [
      "net.arsik.jcraftpolished.fabric.client.JCraftPolishedFabricClient"
    ],
    "fabric-datagen": [
      "net.arsik.jcraftpolished.fabric.datagen.JCraftPolishedDataGen"
    ]
